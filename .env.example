# ── LLM Backend ──────────────────────────────────────────────────────────────
# Supported values: ollama (default), anthropic, openai, mistral
AGENT_BACKEND=ollama

# Model name — leave empty to use the per-backend default:
#   ollama    → mistral-nemo       (pull: ollama pull mistral-nemo)
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o
#   mistral   → mistral-large-latest
#
# Tested local models (tool calling reliability):
#   qwen3:8b-q4_k_m   — best overall (recommended)
#   mistral-nemo       — good for log queries, issues with YAML input
#   llama3.1:8b        — inconsistent tool calling
AGENT_MODEL=qwen3:8b-q4_k_m

# ── Ollama (local inference) ──────────────────────────────────────────────────
# Ollama base URL — must include /v1 (required by OllamaProvider → AsyncOpenAI).
# embed_text() strips /v1 automatically when calling the native /api/embeddings endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Models to pull before first run:
#   ollama pull mistral-nemo       # LLM — tool calling + reliable output
#   ollama pull nomic-embed-text   # embeddings for Docu-RAG

# ── Cloud API keys (only needed for the matching AGENT_BACKEND) ───────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Ports exposed by docker/docker-compose.yml
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Apache Iceberg (PyIceberg + SQLite catalog → MinIO) ───────────────────────
# SQLite-backed catalog: no REST server required. Data lives on MinIO as Parquet.
# Leave ICEBERG_CATALOG_URI empty to fall back to local demo parquet (no Docker).
#
# Seed tables first: uv run -m src.tools.seed_iceberg
ICEBERG_CATALOG_URI=sqlite:///./data/iceberg_catalog.db
ICEBERG_WAREHOUSE=s3://warehouse/iceberg

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_DATA_PATH=./data/local.duckdb
DEMO_LOGS_PATH=./data/logs_seed.parquet

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
# Vector dimension: 768 for nomic-embed-text, 1536 for text-embedding-3-small
EMBEDDING_DIM=768

# ── App server ────────────────────────────────────────────────────────────────
APP_ENV=production
PORT=8000

# ── Observability ─────────────────────────────────────────────────────────────
LOGFIRE_TOKEN=
